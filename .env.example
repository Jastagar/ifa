# Ifa configuration. Copy to `.env` (gitignored) and edit.
#
#   cp .env.example .env
#
# Loaded automatically by ifa/main.py at startup (via python-dotenv).
# Anything set here can also be overridden by exporting in your shell
# or in the launcher script.

# ============================================================
# Mode selection
# ============================================================

# 'text' = type to chat (default).
# 'voice' = wake word + STT pipeline. The run-voice-* launchers
#           force this regardless of what's here.
IFA_MODE=text

# ============================================================
# Wake word (openWakeWord)
# ============================================================

# Built-in names: alexa | hey_jarvis | hey_mycroft | hey_rhasspy
# Or a filesystem path to a custom .onnx model (forward slot for
# custom-trained "hey ifa").
IFA_WAKE_MODEL=hey_mycroft

# Confidence threshold for wake-word detection (0-1). Higher = fewer
# false positives, more missed wakes. Default 0.7.
IFA_WAKE_THRESHOLD=0.7

# Number of consecutive frames that must score above threshold before
# the wake fires. Each frame is 80 ms. Default 2 (= 160 ms sustained).
IFA_WAKE_CONSECUTIVE=2

# ============================================================
# Voice activity detection / utterance capture
# ============================================================

# Trailing silence (ms) that ends an utterance after speech began.
# Default 1500.
IFA_VAD_SILENCE_MS=1500

# Hard cap (ms) on a single utterance. Default 30000.
IFA_VAD_MAX_UTTERANCE_MS=30000

# Speech-probability threshold from Silero VAD (0-1). Default 0.5.
IFA_VAD_THRESHOLD=0.5

# ============================================================
# Speech-to-text (faster-whisper)
# ============================================================

# Model size: tiny.en | base.en | small.en | medium.en | large-v3
# Smaller = faster but less accurate. Default small.en.
IFA_WHISPER_MODEL=small.en

# Compute device: auto | cpu | cuda
#   auto: try CUDA (float16); fall back to CPU (int8) if CUDA unavailable
#   cuda: force CUDA — raises if not available
#   cpu : force CPU — slower but no CUDA dependency
# Default auto.
IFA_WHISPER_DEVICE=auto

# ============================================================
# TTS mute & follow-up window (voice mode only)
# ============================================================

# Cooldown (ms) after TTS playback before the wake-word listener
# resumes scoring real audio. Prevents Ifa from waking herself on
# her own voice via mic bleed-through. Default 500.
IFA_TTS_COOLDOWN_MS=500

# After Ifa replies, skip the wake word for this many seconds so a
# follow-up question (e.g. "what about tomorrow?") is heard
# automatically. Set to 0 to disable. Default 5.
IFA_FOLLOWUP_WINDOW_SEC=5

# ============================================================
# Hugging Face / model downloads
# ============================================================

# Set to 1 to forbid the runtime from making any HF Hub requests.
# Launchers set this AFTER pre-downloading models in setup_voice_models,
# so production launches are fully offline. Leave unset for development
# / model swaps (so first use of a new model can fetch it).
# HF_HUB_OFFLINE=1

# Optional: set to a HF read-only token for faster downloads (no rate
# limits) during the one-time setup. Not used at runtime.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxx
